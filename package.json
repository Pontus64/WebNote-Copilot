{
  "name": "y",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:widget && vite build",
    "build:widget": "vite build --config vite.widget.config.mts && cp dist/widget/floating-notes-widget.js public/embed/floating-notes-widget.js",
    "deploy": "npm run build && wrangler deploy",
    "dev": "vite --host 127.0.0.1",
    "preview": "vite preview --host 127.0.0.1",
    "start": "npm run dev",
    "test": "npm run build && vitest",
    "typecheck": "tsc -p tsconfig.json && tsc -p tsconfig.client.json",
    "cf-typegen": "wrangler types"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.39.0",
    "@cloudflare/vitest-pool-workers": "^0.12.4",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "typescript": "^5.5.2",
    "vite": "^7.3.3",
    "vitest": "~3.2.0",
    "wrangler": "^4.95.0"
  },
  "dependencies": {
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  }
}
