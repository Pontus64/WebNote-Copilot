{
  "name": "y",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:widget && vite build",
    "build:widget": "vite build --config vite.widget.config.mts && cp dist/widget/floating-notes-widget.js public/embed/floating-notes-widget.js && node scripts/strip-trailing-whitespace.mjs public/embed/floating-notes-widget.js",
    "deploy": "npm run build && wrangler deploy",
    "dev": "vite --host 127.0.0.1",
    "preview": "vite preview --host 127.0.0.1",
    "start": "npm run dev",
    "test": "npm run build && vitest",
    "typecheck": "tsc -p tsconfig.json && tsc -p tsconfig.client.json",
    "cf-typegen": "wrangler types"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.39.0",
    "@cloudflare/vitest-pool-workers": "^0.16.10",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "typescript": "^5.5.2",
    "vite": "^7.3.3",
    "vitest": "^4.1.7",
    "wrangler": "^4.95.0"
  },
  "dependencies": {
    "@assistant-ui/react": "^0.14.11",
    "@assistant-ui/react-markdown": "^0.14.1",
    "@milkdown/crepe": "^7.21.1",
    "@milkdown/kit": "^7.21.1",
    "fflate": "^0.8.3",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  }
}
